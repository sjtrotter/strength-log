<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Health Connect permissions (#17, PLAN.md A3). These are on-device IPC
      permissions granted through the Health Connect provider — NOT INTERNET
      (the app still declares no android.permission.INTERNET, so the local-first
      promise holds). Requested lazily and individually at runtime from the Log
      screen; the app is fully functional with any or none of them granted.
    -->
    <uses-permission android:name="android.permission.health.WRITE_EXERCISE" />
    <uses-permission android:name="android.permission.health.WRITE_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />

    <!--
      Lets HealthConnectClient.getSdkStatus see the Health Connect provider on
      API 30+ package-visibility. No launch, no data — just availability.
    -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <!--
      Auto Backup (allowBackup): opts into Google One cloud backup and
      device-to-device transfer for the Room DB + DataStore prefs, at no
      engineering cost. It's a free ride on top of, not a replacement for,
      the versioned JSON full backup (PLAN.md A2, #15/PR #42) — that JSON
      export is the user-visible, guaranteed way to move data on purpose;
      Auto Backup is opaque, best-effort, and skipped if the OEM transfer
      tool doesn't invoke it. dataExtractionRules covers API 31+; the
      identical fullBackupContent rules back-fill the API 26-30 floor.
    -->
    <application
        android:name=".StrengthLogApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher_day_a"
        android:roundIcon="@mipmap/ic_launcher_day_a"
        android:theme="@style/Theme.StrengthLog"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules">

        <!--
          MainActivity is never launched directly — only through one of the
          Launcher_Day* aliases below, which is what carries the LAUNCHER
          intent-filter and the day-specific icon. Unexported so there's no
          second, iconless path into the app.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!--
          Health Connect's mandatory permissions-rationale target (#17). The
          provider launches this to explain why the app requests health
          permissions. Exported (it has to be launchable by the Health Connect
          provider) but inert: it shows a static, on-device rationale screen and
          reads no data. Two filters cover both eras — the pre-14 provider APK
          fires SHOW_PERMISSIONS_RATIONALE; platform Health Connect (API 34+)
          fires VIEW_PERMISSION_USAGE with the HEALTH_PERMISSIONS category. The
          full privacy-policy page is #23's job.
        -->
        <activity
            android:name=".health.HealthRationaleActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.health.connect.action.SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>
        <activity-alias
            android:name=".health.ViewPermissionUsageActivity"
            android:targetActivity=".health.HealthRationaleActivity"
            android:exported="true"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!--
          Wear Data Layer receiver (#20). Google Play Services binds this service
          to deliver watch->phone set-edit messages, waking the app process if it
          was dead so an edit made while the phone app wasn't running still lands.

          exported="true" is required and safe: only Google Play Services binds a
          WearableListenerService (the bind is gated by that trusted process), and
          the filter is path-scoped to /strengthlog so nothing but our own
          set-edit messages can reach it. The service validates and dedupes every
          payload before touching data (SetEditApplier), and no INTERNET permission
          is added — the Data Layer is on-device Play-services IPC.
        -->
        <service
            android:name=".sync.StrengthLogWearListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/strengthlog" />
            </intent-filter>
        </service>

        <!--
          Day-swapping launcher icon (#22): one alias per rotation day, one
          icon each. DayIconManager enables the alias for the current
          suggested day and disables the rest via PackageManager component
          toggling — no new permission, no network. Day A ships enabled so a
          fresh install always shows exactly one icon.
        -->
        <activity-alias
            android:name=".Launcher_DayA"
            android:targetActivity=".MainActivity"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_day_a"
            android:roundIcon="@mipmap/ic_launcher_day_a">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".Launcher_DayB"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_day_b"
            android:roundIcon="@mipmap/ic_launcher_day_b">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".Launcher_DayC"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_day_c"
            android:roundIcon="@mipmap/ic_launcher_day_c">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".Launcher_DayD"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_day_d"
            android:roundIcon="@mipmap/ic_launcher_day_d">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".Launcher_DayE"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_day_e"
            android:roundIcon="@mipmap/ic_launcher_day_e">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".Launcher_DayF"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_day_f"
            android:roundIcon="@mipmap/ic_launcher_day_f">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".Launcher_DayG"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_day_g"
            android:roundIcon="@mipmap/ic_launcher_day_g">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
    </application>

</manifest>
